rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() { return request.auth != null; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }

    function isValidAppState(data) {
      return data.keys().hasAll(['inventory', 'accounts', 'settings', 'customers', 'suppliers', 'transactions', 'userId', 'updatedAt'])
        && data.keys().size() == 8
        && data.userId == request.auth.uid // Identity integrity
        && data.inventory is map
        && data.accounts is map
        && data.settings is map
        && data.customers is list && data.customers.size() <= 3000
        && data.suppliers is list && data.suppliers.size() <= 3000
        && data.transactions is list && data.transactions.size() <= 5000
        && data.userId is string && data.userId.size() <= 128
        && (data.updatedAt is string || data.updatedAt is timestamp);
    }

    match /bousala_states/{userId} {
      allow read: if isSignedIn() && request.auth.uid == userId;

      allow create: if isSignedIn() 
        && isValidId(userId)
        && request.auth.uid == userId 
        && isValidAppState(incoming());

      allow update: if isSignedIn() 
        && isValidId(userId)
        && request.auth.uid == userId 
        && isValidAppState(incoming())
        && existing().userId == incoming().userId;
    }
  }
}
